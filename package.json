{
  "name": "aws-resource-dependency-mapper",
  "version": "0.1.0",
  "description": "Desktop app to discover and visualize AWS resource dependencies from any ARN.",
  "main": "out/main/index.js",
  "author": "",
  "license": "MIT",
  "private": true,
  "type": "module",
  "bin": {
    "aws-resource-dependency-mapper": "./bin/start.js"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite dev",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "build": "npm run typecheck && electron-vite build",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win nsis",
    "pack": "npm run build && electron-builder --dir"
  },
  "dependencies": {
    "@electron-toolkit/preload": "3.0.2",
    "html-to-image": "1.11.13",
    "lucide-react": "0.468.0",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "22.19.21",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "5.2.0",
    "electron": "41.7.2",
    "electron-builder": "26.15.3",
    "electron-vite": "5.0.0",
    "eslint": "9.39.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.61.0",
    "vite": "7.3.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "build": {
    "appId": "com.awsresourcedependencymapper.app",
    "productName": "AWS Resource Dependency Mapper",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
